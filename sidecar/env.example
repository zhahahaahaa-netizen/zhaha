# Copy this file to ".env" and fill in your own values.
# NEVER commit the real ".env" file. NEVER paste your private key in chat,
# in code comments, in commit messages, or in screenshots.

# Your wallet's private key (from a wallet you generated for THIS project only)
PRIVATE_KEY=YOUR_PRIVATE_KEY
# 0G testnet endpoints (Turbo indexer recommended for speed)
RPC_URL=https://evmrpc-testnet.0g.ai
INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# A stream ID for the key-value store — any string unique to your app is fine
STREAM_ID=0x0c2a2d101aba16831fd325bb3b20441dafc45a769f05ec4d7e5293ba45c5f1ba

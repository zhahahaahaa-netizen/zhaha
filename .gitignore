# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging (PyInstaller output)
build/
dist/
*.egg-info/
.eggs/
*.spec

# Virtual environments
venv/
.venv/
env/
ENV/

# IDE
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Config / state files your app generates at runtime
config.json
settings.json
sidecar/settings.json

# Environment variables / secrets - NEVER commit these
.env
sidecar/.env
*.env

# Node.js dependencies (huge, regenerated via npm install)
node_modules/
sidecar/node_modules/
